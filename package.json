{
  "name": "google-maps-mentor",
  "version": "1.0.0",
  "homepage": "https://googlementor.com",
  "scripts": {
    "dev": "next dev",
    "validate:llms": "node scripts/validate-llms.js",
    "validate:intent-registry": "tsx scripts/validate-intent-registry.ts",
    "validate:intent-pages": "tsx scripts/validate-intent-pages.ts",
    "validate:homepage-links": "tsx scripts/validate-homepage-links.ts",
    "validate:meta-descriptions": "tsx scripts/validate-meta-descriptions.ts",
    "report:intent-coverage": "tsx scripts/generate-intent-coverage.ts",
    "data:validate": "tsx scripts/validate-data.ts",
    "data:generate-entities": "tsx scripts/generate-entities.ts",
    "data:prepare": "run-s data:validate data:generate-entities",
    "prebuild": "node -e \"const fs = require('fs'); const path = require('path'); const src = 'src/data'; const dest = 'public/data'; if (!fs.existsSync(dest)) fs.mkdirSync(dest, {recursive: true}); fs.readdirSync(src).filter(f => f.endsWith('.json')).forEach(f => fs.copyFileSync(path.join(src, f), path.join(dest, f)));\" && node scripts/generate-place-enrichment.js",
    "data:generate-place-enrichment": "node scripts/generate-place-enrichment.js",
    "validate:guide-entity-targets": "node scripts/validate-guide-entity-targets.js",
    "build": "npm run validate:llms && npm run validate:intent-registry && npm run report:intent-coverage && npm run validate:intent-pages && npm run validate:homepage-links && npm run validate:guide-entity-targets && npm run validate:meta-descriptions && node scripts/run-next-build-with-retry.js",
    "build:fast": "npm run build",
    "build:clean-first": "cross-env NEXT_BUILD_CLEAN_FIRST_ATTEMPT=1 npm run build",
    "postbuild": "node scripts/generate-trailing-slash-aliases.js && next-sitemap --config next-sitemap.config.js && node scripts/sanitize-sitemap.js && node scripts/generate-llms-full.js && node scripts/validate-knowledge-graph.js && node scripts/submit-to-indexnow.js",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "build-prod": "run-s clean build",
    "clean": "rimraf .next out",
    "lint": "next lint",
    "data:stabilize": "node scripts/add-stable-ids-and-slugs.js",
    "validate:knowledge-graph": "node scripts/validate-knowledge-graph.js",
    "build-types": "tsc --noEmit --pretty",
    "test:itinerary-utils": "tsx scripts/test-itinerary-utils.ts",
    "indexnow:generate-key": "node scripts/generate-indexnow-key.js",
    "indexnow:submit": "node scripts/submit-to-indexnow.js",
    "predeploy": "npm run clean && npm run build",
    "deploy": "gh-pages -d out",
    "predeploy:fast": "npm run build",
    "deploy:fast": "gh-pages -d out",
    "preview": "serve out"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.7",
    "@chakra-ui/icons": "^2.0.0",
    "@chakra-ui/react": "^2.6.0",
    "@chakra-ui/styled-system": "^2.12.0",
    "@chakra-ui/theme-tools": "^2.2.6",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@headlessui/react": "^2.2.2",
    "@heroicons/react": "^2.2.0",
    "@types/react-dom": "^18.3.1",
    "framer-motion": "^10.12.16",
    "gh-pages": "^6.1.1",
    "gray-matter": "^4.0.3",
    "i18next": "^25.0.1",
    "lodash.debounce": "^4.0.8",
    "next": "^15.0.6",
    "next-mdx-remote": "^5.0.0",
    "next-sitemap": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.5",
    "react-icons": "^5.4.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@next/bundle-analyzer": "^15.0.6",
    "@types/lodash.debounce": "^4.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.1",
    "@types/serviceworker": "^0.0.158",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.6",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2"
  }
}
